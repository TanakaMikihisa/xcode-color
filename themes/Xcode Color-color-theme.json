	"tokenColors": [
		{
			"name": "Comment",
			"scope": [
				"comment",
				"punctuation.definition.comment",
				"comment.line",
				"comment.block"
			],
			"settings": {
				"foreground": "#6C7986"
			}
		},
		{
			"name": "Documentation comment (Swift / similar)",
			"scope": [
				"comment.block.documentation",
				"comment.line.documentation"
			],
			"settings": {
				"foreground": "#6C7986"
			}
		},
		{
			"name": "Keyword & storage",
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.operator.new",
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#FF7AB2"
			}
		},
		{
			"name": "Operator (general)",
			"scope": [
				"keyword.operator",
				"punctuation.accessor"
			],
			"settings": {
				"foreground": "#D0D0D0"
			}
		},
		{
			"name": "Punctuation",
			"scope": [
				"punctuation",
				"punctuation.separator",
				"punctuation.terminator",
